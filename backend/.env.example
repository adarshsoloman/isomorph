# App Settings
PROJECT_NAME=isomorph
ENVIRONMENT=development
PIPELINE_VERSION=v0.1

# Database Settings
POSTGRES_USER=isomorph
POSTGRES_PASSWORD=isomorph
POSTGRES_DB=isomorph_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://isomorph:isomorph@localhost:5432/isomorph_db

# External APIs
GROQ_API_KEY=your_groq_api_key_here

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Constants
MIN_SIMILARITY_SCORE=0.6
MAX_ANALYSES_PER_USER=10
CACHE_TTL=3600
